# Plex (local on Whatbox)
PLEX_URL=https://127.0.0.1:31711
PLEX_TOKEN=

# Artist enrichment
LASTFM_API_KEY=
DISCOGS_TOKEN=

# Admin
ADMIN_TOKEN=changeme

# Music files (Whatbox path)
MUSIC_BASE_PATH=/home/yolan/files/Webradio

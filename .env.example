# GAENDE Radio — environment variables.
# Copy to ~/.gaende.env on Whatbox (`chmod 600`); deploy.sh sources it before launching
# the bridge. Key names must match what config/config.go reads — don't rename without
# updating both places.

# Bridge
HOST=0.0.0.0
PORT=3001

# Postgres (Podman container). POSTGRES_PASSWORD is the same variable docker-compose and
# deploy.sh use; DATABASE_URL is what the Go bridge reads. Keep them in sync.
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://gaende:changeme@localhost:15432/gaende?sslmode=disable

# Cache (Podman container; currently unused by bridge code)
REDIS_URL=redis://localhost:16379

# Search (Podman container; currently unused — search falls back to Postgres ILIKE)
MEILI_URL=http://localhost:7700
MEILI_KEY=changeme

# Plex (local on Whatbox). With Phase D disk-consumer landed, the Go bridge no longer
# needs PLEX_TOKEN — Python sync (scripts/plex-sync/) is the only authenticated consumer.
# Leaving the var here so older bridge builds still find it during transition.
PLEX_URL=https://127.0.0.1:31711
PLEX_TOKEN=

# Artist enrichment (Last.fm). The bridge reads LASTFM_API_KEY; an older deploy.sh used
# LASTFM_KEY which silently disabled enrichment.
LASTFM_API_KEY=
DISCOGS_TOKEN=

# Admin
ADMIN_TOKEN=changeme

# Music files (Whatbox path). Points at the root of the Webradio symlink tree that
# Python sync populates. Used by the bridge's file_path canonicalizer.
MUSIC_BASE_PATH=/home/yolan/files/Webradio

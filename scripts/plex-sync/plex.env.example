# Plex → Webradio sync credentials.
# Install to ~/.config/gaende/plex.env on Whatbox; start.sh auto-sources it.
# chmod 600 ~/.config/gaende/plex.env

PLEX_USERNAME=your.plex.account@example.com
PLEX_PASSWORD=your_plex_password
PLEX_SERVERNAME=AEGIR

# Optional overrides (defaults shown)
# WEBRADIO_FOLDER=/home/yolan/files/Webradio
# SERVER_MUSIC=/home/yolan/files/plex_music_library/opus/
